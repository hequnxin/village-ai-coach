# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# JWT 密钥
JWT_SECRET=your_jwt_secret_here_change_me

# 百度搜索（可选）
BAIDU_API_KEY=your_baidu_api_key_here

# 阿里云 DashScope（可选）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 服务端口
PORT=3001
OFFLINE_MODE=false

# 数据库（使用 Supabase 或本地 PostgreSQL）
DATABASE_URL=postgresql://username:password@host:port/database

# 腾讯云 TRTC（语音通话）
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TRTC_SDK_APP_ID=your_trtc_sdk_app_id
TRTC_SECRET_KEY=your_trtc_secret_key

# AI 回调公网地址（用于腾讯云回调）
AI_CALLBACK_BASE_URL=https://your-domain.onrender.com